{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "spoonfish-landing-page",
  "main": "src/index.js",
  "compatibility_date": "2026-04-17",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  },
  "kv_namespaces": [
    {
      "binding": "WAITLIST",
      "id": "45d1e35f867842539537ee1541b3f0e0"
    }
  ]
}
