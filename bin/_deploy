#!/usr/bin/env bash
# Sync Bitwarden-managed Worker secrets to Cloudflare, then deploy.
# Invoked inside `bws run`, so all project secrets are present in env.
# Called via `just deploy` — not run directly.

set -euo pipefail

DIR="$(cd "$(dirname "$0")" && pwd)"
"$DIR/_secrets-sync"

wrangler deploy
