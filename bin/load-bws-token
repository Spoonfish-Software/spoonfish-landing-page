#!/usr/bin/env bash
# Loads BWS_ACCESS_TOKEN from macOS Keychain into the current shell.
#
# One-time setup (paste token at the interactive prompt, then hit Ctrl-D):
#   security add-generic-password -a "$USER" -s "bws-spoonfish-software" -w
#
# CI does NOT use this script — it sets BWS_ACCESS_TOKEN via GitHub Actions secret.

token="$(security find-generic-password -a "$USER" -s "bws-spoonfish-software" -w 2>/dev/null)"
if [ -z "$token" ]; then
  echo "BWS token not in keychain. See header of bin/load-bws-token for setup." >&2
  return 1 2>/dev/null || exit 1
fi
export BWS_ACCESS_TOKEN="$token"
unset token
