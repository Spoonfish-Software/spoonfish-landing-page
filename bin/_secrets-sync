#!/usr/bin/env bash
# Push Bitwarden-managed Worker runtime secrets to Cloudflare via wrangler secret bulk.
# Invoked inside `bws run`, so all project secrets are present in env.
# Called via `just secrets-sync` and from bin/_deploy — not run directly.
#
# Adding a new Bitwarden-managed Worker secret? Add it here AND in the jq invocation below.
# Worker code reads from env.* at runtime; wrangler secret bulk binds env.* server-side.

set -euo pipefail

jq -n \
  --arg OPS_CELL_NUMBER       "$OPS_CELL_NUMBER" \
  --arg SIGNALWIRE_API_TOKEN  "$SIGNALWIRE_API_TOKEN" \
  --arg TURNSTILE_SECRET      "$TURNSTILE_SECRET" \
  '{
    OPS_CELL_NUMBER:       $OPS_CELL_NUMBER,
    SIGNALWIRE_API_TOKEN:  $SIGNALWIRE_API_TOKEN,
    TURNSTILE_SECRET:      $TURNSTILE_SECRET
  }' \
| wrangler secret bulk
